# Campaign Respond Configuration
# Copy to .env and fill in values

# Claude API (required for API mode, not needed for CLI mode)
ANTHROPIC_API_KEY=

# Notification settings
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=ctgiii@pm.me
SMTP_FROM=ctgiii@pm.me

# Twilio SMS (optional)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Google Drive OAuth (generated during setup)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OneDrive OAuth (generated during setup)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=

# Homelab detection
HOMELAB_ROOT=
